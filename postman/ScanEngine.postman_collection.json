{
  "info": {
    "name": "ScanEngine",
    "description": "Deterministic CEP scanner engine — GraphQL API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" }
  ],
  "item": [
    {
      "name": "Health - Live",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health/live", "host": ["{{baseUrl}}"], "path": ["health", "live"] }
      }
    },
    {
      "name": "Health - Ready",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health/ready", "host": ["{{baseUrl}}"], "path": ["health", "ready"] }
      }
    },
    {
      "name": "Metrics",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/metrics", "host": ["{{baseUrl}}"], "path": ["metrics"] }
      }
    },
    {
      "name": "Mutation - addRule",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"query\":\"mutation($input: RuleInput!){ addRule(input:$input) }\",\"variables\":{\"input\":{\"name\":\"breakout-above-100\",\"conditions\":[{\"field\":\"LAST_PRICE\",\"comparator\":\"CROSS_ABOVE\",\"threshold\":100}]}}}"
        },
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] }
      }
    },
    {
      "name": "Mutation - removeRule",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"query\":\"mutation($id: String!){ removeRule(id:$id) }\",\"variables\":{\"id\":\"00000000-0000-0000-0000-000000000000\"}}"
        },
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] }
      }
    },
    {
      "name": "Mutation - ingestTick",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"query\":\"mutation($input: TickInput!){ ingestTick(input:$input){ ruleName instrument lastPrice pctChangeBps explanation triggeredAt } }\",\"variables\":{\"input\":{\"instrument\":\"NSE:TCS\",\"lastPrice\":150,\"volume\":2}}}"
        },
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] }
      }
    },
    {
      "name": "Query - rules",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"query\":\"{ rules { id name scope conditions { field comparator threshold } } }\"}"
        },
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] }
      }
    },
    {
      "name": "Query - state",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"query\":\"{ state(instrument:\\\"NSE:TCS\\\"){ open last high low volume pctChangeBps } }\"}"
        },
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] }
      }
    },
    {
      "name": "Query - stats",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"query\":\"{ stats { ticksProcessed ticksRejected evaluations signalsEmitted rules instruments evaluationsPerTick } }\"}"
        },
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] }
      }
    }
  ]
}
